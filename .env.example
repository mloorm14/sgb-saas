# ─────────────────────────────────────────────────────────────
# SGB-SaaS — Variables de entorno
# Copiar este archivo: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# JWT — Generar con: openssl rand -hex 32  (mínimo 256 bits)
JWT_SECRET=cambiar_por_clave_de_minimo_32_caracteres_generada_con_openssl

# Base de datos PostgreSQL
DB_URL=jdbc:postgresql://postgres:5432/sgb_db
DB_USER=sgb_user
DB_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
